[
  {
    "testName": "Login with valid username and password",
    "steps": [
      {
        "action": "goto",
        "url": "https://practicetestautomation.com/practice-test-login/"
      },
      {
        "action": "fill",
        "selector": "#username",
        "value": "validUser"
      },
      {
        "action": "fill",
        "selector": "#password",
        "value": "validPass123"
      },
      {
        "action": "click",
        "selector": "#submit"
      }
    ]
  },
  {
    "testName": "Open menu button toggles navigation",
    "steps": [
      {
        "action": "goto",
        "url": "https://practicetestautomation.com/practice-test-login/"
      },
      {
        "action": "click",
        "selector": "#toggle-navigation"
      }
    ]
  },
  {
    "testName": "Submit button is displayed and clickable",
    "steps": [
      {
        "action": "goto",
        "url": "https://practicetestautomation.com/practice-test-login/"
      },
      {
        "action": "assertVisible",
        "selector": "#submit"
      }
    ]
  },
