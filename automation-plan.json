  {
    "testName": "Username field accepts 256 characters input",
    "steps": [
      {
        "action": "goto",
        "url": "https://practicetestautomation.com/practice-test-login/"
      },
      {
        "action": "fill",
        "selector": "#username",
        "value": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
      },
      {
        "action": "fill",
        "selector": "#password",
        "value": "validPass123"
      },
      {
        "action": "click",
        "selector": "#submit"
      }
    ]
  },
  {
    "testName": "Password field accepts special characters and spaces",
    "steps": [
      {
        "action": "goto",
        "url": "https://practicetestautomation.com/practice-test-login/"
      },
      {
        "action": "fill",
        "selector": "#username",
        "value": "validUser"
      },
      {
        "action": "fill",
        "selector": "#password",
        "value": "!@# $%^&*()_+{}|:\"<>?"
      },
      {
        "action": "click",
        "selector": "#submit"
      }
    ]
  },
  {
    "testName": "Input fields with whitespace only",
    "steps": [
      {
        "action": "goto",
        "url": "https://practicetestautomation.com/practice-test-login/"
      },
      {
        "action": "fill",
        "selector": "#username",
        "value": "     "
      },
      {
        "action": "fill",
        "selector": "#password",
        "value": "\t  "
      },
      {
        "action": "click",
        "selector": "#submit"
      }
    ]
  },
  {
    "testName": "Open menu button accessibility with keyboard",
    "steps": [
      {
        "action": "goto",
        "url": "https://practicetestautomation.com/practice-test-login/"
      },
      {
        "action": "focus",
        "selector": "#toggle-navigation"
      },
      {
        "action": "pressKey",
        "selector": "#toggle-navigation",
        "value": "Enter"
      }
    ]
  },
  {
    "testName": "Submit login form using Enter key",
    "steps": [
      {
        "action": "goto",
        "url": "https://practicetestautomation.com/practice-test-login/"
      },
      {
        "action": "fill",
        "selector": "#username",
        "value": "validUser"
      },
      {
        "action": "fill",
        "selector": "#password",
        "value": "validPass123"
      },
      {
        "action": "pressKey",
        "selector": "#password",
        "value": "Enter"
      }
    ]
  }
